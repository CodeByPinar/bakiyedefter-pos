{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["apps/desktop/renderer/src/*"],
      "@shared/*": ["packages/shared/*"]
    }
  },
  "include": [
    "apps/desktop/renderer/src/**/*.ts",
    "apps/desktop/renderer/src/**/*.tsx",
    "apps/desktop/electron/preload/api-contract.ts",
    "packages/shared/**/*.ts"
  ]
}
